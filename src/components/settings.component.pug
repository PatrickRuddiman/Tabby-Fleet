ngb-accordion
  ngb-panel(title='Repo')
    ng-template(ngbPanelHeader)
      | Repo
    ng-template(ngbPanelContent)
      .form-group
        label Repo path
        input.form-control(type='text' [(ngModel)]='profile.options.repoPath' placeholder='leave empty for current directory')
      .form-group
        label Pre-launch command
        input.form-control(type='text' [(ngModel)]='profile.options.preSpawnCommand')

  ngb-panel(title='Templates')
    ng-template(ngbPanelHeader)
      | Templates
    ng-template(ngbPanelContent)
      .form-group
        label Root command template
        input.form-control(type='text' [(ngModel)]='profile.options.rootCommandTemplate')
        small.form-text.text-muted Variables: {path} {path_native} {branch} {branch_short} {name} {head} {head_short} {repo} {repo_path}
      .form-group
        label Root title template
        input.form-control(type='text' [(ngModel)]='profile.options.rootTitle')
        small.form-text.text-muted Same variables as root command template.
      .form-group
        label Worktree command template
        input.form-control(type='text' [(ngModel)]='profile.options.commandTemplate')
        small.form-text.text-muted Variables: {path} {path_native} {branch} {branch_short} {name} {head} {head_short} {repo} {repo_path}
      .form-group
        label Worktree pane title pattern
        input.form-control(type='text' [(ngModel)]='profile.options.paneTitlePattern')
        small.form-text.text-muted Same variables as worktree command template.

  ngb-panel(title='Filters')
    ng-template(ngbPanelHeader)
      | Filters
    ng-template(ngbPanelContent)
      .form-group
        label Worktree path prefix
        input.form-control(type='text' [(ngModel)]='profile.options.worktreePathPrefix')
      .form-check
        input.form-check-input(type='checkbox' [(ngModel)]='profile.options.includeDetached' id='inc-detached')
        label.form-check-label(for='inc-detached') Include detached worktrees
      .form-check
        input.form-check-input(type='checkbox' [(ngModel)]='profile.options.includePrunable' id='inc-prunable')
        label.form-check-label(for='inc-prunable') Include prunable worktrees
      .form-check
        input.form-check-input(type='checkbox' [(ngModel)]='profile.options.includeLocked' id='inc-locked')
        label.form-check-label(for='inc-locked') Include locked worktrees

  ngb-panel(title='Layout')
    ng-template(ngbPanelHeader)
      | Layout
    ng-template(ngbPanelContent)
      .form-group
        label Layout mode
        select.form-control([(ngModel)]='profile.options.layoutMode')
          option(value='grid') Auto-zoom grid
          option(value='static-grid') Static grid (no zoom)
      .form-group
        label Zoom factor
        input.form-control(type='number' step='0.1' min='1' max='4' [(ngModel)]='profile.options.zoomFactor' (blur)='clampField("zoomFactor")')
      .form-group
        label Min pane width (px)
        input.form-control(type='number' min='40' [(ngModel)]='profile.options.minPaneWidth' (blur)='clampField("minPaneWidth")')
      .form-group
        label Min pane height (px)
        input.form-control(type='number' min='40' [(ngModel)]='profile.options.minPaneHeight' (blur)='clampField("minPaneHeight")')
      .form-group
        label Zoom transition (ms)
        input.form-control(type='number' min='0' max='1000' [(ngModel)]='profile.options.zoomTransitionMs' (blur)='clampField("zoomTransitionMs")')

  ngb-panel(title='Watcher')
    ng-template(ngbPanelHeader)
      | Watcher
    ng-template(ngbPanelContent)
      .form-group
        label Watch mode
        select.form-control([(ngModel)]='profile.options.watchMode')
          option(value='fs') Filesystem events
          option(value='poll') Polling
          option(value='off') Off
      .form-group
        label Poll interval (ms)
        input.form-control(type='number' min='500' max='60000' [(ngModel)]='profile.options.pollIntervalMs' (blur)='clampField("pollIntervalMs")')
      .form-check
        input.form-check-input(type='checkbox' [(ngModel)]='profile.options.autoOpenNew' id='auto-open')
        label.form-check-label(for='auto-open') Auto-open new worktree panes
      .form-check
        input.form-check-input(type='checkbox' [(ngModel)]='profile.options.autoCloseRemoved' id='auto-close')
        label.form-check-label(for='auto-close') Auto-close removed worktree panes

  ngb-panel(title='Notifications')
    ng-template(ngbPanelHeader)
      | Notifications
    ng-template(ngbPanelContent)
      .form-check
        input.form-check-input(type='checkbox' [(ngModel)]='profile.options.stealFocusOnAdd' id='steal-focus')
        label.form-check-label(for='steal-focus') Focus newly-added panes
      .form-check
        input.form-check-input(type='checkbox' [(ngModel)]='profile.options.notifyOnChange' id='notify-change')
        label.form-check-label(for='notify-change') Notify when panes are added or removed

  ngb-panel(title='Shell')
    ng-template(ngbPanelHeader)
      | Shell
    ng-template(ngbPanelContent)
      .form-group
        label Shell program
        input.form-control(type='text' [(ngModel)]='profile.options.shell')
      .form-group
        label Shell arguments (one per line)
        textarea.form-control(rows='4' [(ngModel)]='shellArgsText')
      .form-group
        label Encoding mode
        select.form-control([(ngModel)]='profile.options.encoding')
          option(value='encoded') Encoded (-EncodedCommand)
          option(value='command') Command wrapper (& { ... })
      .form-group
        label Spawn mode
        select.form-control([(ngModel)]='profile.options.spawnMode')
          option(value='eager') Eager (open all panes at launch)
          option(value='lazy') Lazy (open on first interaction)
      .form-group
        label Root pane color (hex, e.g. #1976d2)
        input.form-control(type='text' [(ngModel)]='profile.options.rootColor')
      .form-group
        label Worktree pane color (hex, e.g. #43a047)
        input.form-control(type='text' [(ngModel)]='profile.options.paneColor')
