.modal-header
  h4.modal-title Close this fleet?
  button.btn-close(type='button' aria-label='Close' (click)='cancel()')

.modal-body
  p
    | Closing the root will close the entire fleet tab and stop monitoring
    |
    code {{ repoName }}
    | .

.modal-footer
  button.btn.btn-secondary(type='button' (click)='cancel()') Cancel
  button.btn.btn-danger(type='button' (click)='confirm()') Close fleet
